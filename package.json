{
  "name": "bkg",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@8.15.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint --continue",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "check": "turbo run check --continue"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "turbo": "^1.11.0",
    "prettier": "^3.2.5"
  }
}
